checkJobs()
if terminal.jobs.len == 0 (
  terminal.writeLine("No active jobs")
) else (
  for i terminal.jobs.len (
    local job = terminal.jobs[i]
    local status = job.worker.done ? "done" : (job.worker.dead ? "dead" : "running")
    terminal.writeLine("[" ++ job.id ++ "] " ++ status ++ " - " ++ job.name)
  )
)
